<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.layout-switcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <!-- ЗАМЕНИ НА ПОЛНЫЙ ПУТЬ К СКРИПТУ: -->
        <string>/Users/ТВОЙ_ЮЗЕР/layout_switcher/layout_switcher.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/layout_switcher.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/layout_switcher_err.log</string>
</dict>
</plist>
